      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(pagamentos_pago_confirmed_total[$__range])) / clamp_min(sum(increase(pagamentos_pagar_consumed_total[$__range])), 1)",
          "legendFormat": "confirm rate",
          "refId": "A"
        },
        {
          "expr": "sum(increase(pagamentos_compensations_total[$__range])) / clamp_min(sum(increase(pagamentos_pagar_consumed_total[$__range])), 1)",
          "legendFormat": "compensation rate",
          "refId": "B"
        }
      ],
      "title": "Outcome Ratios (Range)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
